# ============================================================================
# rag-service 配置（与主系统 ai-agent-learning/config.yaml 共用同一套凭证）
# 拷贝为 .env 后填入主系统同款 key
# ============================================================================

# ---- 服务 ----
PORT=8001

# ---- Qdrant（与主系统 config.yaml 中 qdrant_url / qdrant_api_key 一致） ----
QDRANT_URL=http://your-qdrant-host:6333
QDRANT_API_KEY=your-qdrant-api-key

# ---- Embedding（与主系统 config.yaml 中 embedding_* 一致） ----
EMBEDDING_PROVIDER=google
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072
EMBEDDING_BATCH_SIZE=64

# ---- MinerU 云端 PDF 解析（论文核心；留空则降级 PyMuPDF） ----
MINERU_API_TOKEN=
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_MODEL_VERSION=vlm
MINERU_TIMEOUT=600
MINERU_POLL_INTERVAL=3

# ---- HyDE 查询改写（默认关闭） ----
HYDE_ENABLED_BY_DEFAULT=false
HYDE_LLM_BASE_URL=http://your-llm-gateway/v1
HYDE_LLM_API_KEY=your-llm-api-key
HYDE_LLM_MODEL=qwen3.6-flash

# ============================================================================
# RERANKER（重排器，5 选 1）
#
# 启用方式：把下面 2 行按需修改，其余 RERANKER_* 配置默认注释掉，只在对应
# provider 启用时取消注释。
#
#   RERANKER_ENABLED=false            ← true 启用，false 完全禁用（默认）
#   RERANKER_PROVIDER=flashrank       ← disabled | flashrank | jina | llm | local
#
# 选型对照：
#   disabled   完全不重排，零依赖（默认）
#   flashrank  ONNX 本地推理，18-120MB，2核4G 推荐
#   jina       在线 API，免费 1M token/月（需 https://jina.ai 注册）
#   llm        复用主系统 LLM 网关给候选打分
#   local      BAAI/bge-reranker-v2-m3，~568MB，论文实验场景
# ============================================================================
RERANKER_ENABLED=false
RERANKER_PROVIDER=flashrank

# --- flashrank provider（启用时取消注释） ---
# RERANKER_FLASHRANK_MODEL=rank-T5-flan
# RERANKER_FLASHRANK_CACHE_DIR=data/flashrank_cache
# 模型选项（按大小/精度）：ms-marco-TinyBERT-L-2-v2 / ms-marco-MiniLM-L-12-v2 / rank-T5-flan

# --- jina provider（启用时取消注释） ---
# RERANKER_JINA_API_KEY=your-jina-key
# RERANKER_JINA_MODEL=jina-reranker-v2-base-multilingual
# RERANKER_JINA_BASE_URL=https://api.jina.ai/v1/rerank

# --- llm provider（启用时取消注释；默认复用 HyDE/主系统 LLM） ---
# RERANKER_LLM_BASE_URL=
# RERANKER_LLM_API_KEY=
# RERANKER_LLM_MODEL=

# --- local provider（启用时取消注释） ---
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ============================================================================
# 检索侧调参（毕设论文实验维度，按需调整）
# ============================================================================
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_TOP_K=10

RRF_K=60
RRF_VECTOR_WEIGHT=0.7
RRF_SPARSE_WEIGHT=0.3

HTTP_TIMEOUT=30
SCORE_THRESHOLD=0.3
METADATA_DB_PATH=data/rag_metadata.db

# 公式 LaTeX 深度规范化（sympy / latex2sympy2，懒加载；未装库自动降级）
FORMULA_VALIDATION_ENABLED=false

# 检索融合与去重
NORMALIZE_SCORES_BEFORE_FUSION=true
DIVERSITY_PENALTY=0.1            # 0=关闭；同文档衰减
DIVERSITY_FLOOR=0.5              # 同文档衰减下限
DEDUP_JACCARD_THRESHOLD=0.7      # 1=禁用去重
